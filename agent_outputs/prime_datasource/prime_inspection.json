  "risks": [
    {
      "id": "RISK-001",
      "severity": "HIGH",
      "description": "Giant abundance matrix files require chunked streaming",
      "detail": "gg_species_relative.csv (1.8 GB) and gg_species_absolute.csv (1.6 GB) cannot be loaded atomically. silva_genus_relative.csv and silva_species_relative.csv are each 581 MB. GG species files have 25,401 column headers — memory pressure even for the header row.",
      "mitigation": "Use pandas read_csv with chunksize=1000. Consider silva_genus_relative.csv as primary abundance file for MVP (581 MB, 12,042 taxa). Use encoding='utf-8-sig' to handle BOM."
    },
    {
      "id": "RISK-002",
      "severity": "HIGH",
      "description": "No NCBI Taxonomy numeric IDs — taxa identified only by lineage strings",
      "detail": "Abundance matrix column headers are lineage strings like 'd__Bacteria;p__Firmicutes;...;g__Lactobacillus'. Not NCBI taxon IDs. The PRIME taxa API uses internal integer IDs only.",
      "mitigation": "Store lineage strings directly as taxon identifiers. Add a post-processing step to map lineage strings to NCBI taxon IDs via taxonkit or NCBI Taxonomy API if cross-referencing is required."
    },
    {
      "id": "RISK-003",
      "severity": "MEDIUM",
      "description": "Wide-format abundance matrices must be transposed per sample",
      "detail": "Abundance CSVs are wide (rows=samples, up to 25,401 columns=taxa). BioThings documents are per-sample. Plugin must pivot each row into a sample document with an abundance dict.",
      "mitigation": "For each sample row, build a dict of {taxon_lineage: abundance_value}, filtering zero values. Store as nested object under sample._id."
    },
    {
      "id": "RISK-004",
      "severity": "MEDIUM",
      "description": "High sparsity in host metadata fields",
      "detail": "85 columns in samples_metadata.csv but columns 36-84 (Host_Age, Host_Sex, Tumor_Stage, Endo_*, Sperm_*, etc.) are null for most samples — each field is study-specific.",
      "mitigation": "Filter out null/empty fields at ingest time. Only include non-null values in the BioThings document."
    },
    {
      "id": "RISK-005",
      "severity": "MEDIUM",
      "description": "Zenodo record versioning — URLs may change on dataset update",
      "detail": "Download URLs reference record ID 15711237. PRIME updates every 24 hours on the live site; if they release a new Zenodo record, URLs change.",
      "mitigation": "Track the Zenodo DOI (10.5281/zenodo.15711237). Confirm the Zenodo concept DOI for always-latest resolution. Build a version-check step in the plugin."
    },
    {
      "id": "RISK-006",
      "severity": "LOW",
      "description": "UTF-8 BOM in CSV headers",
      "detail": "Both samples_metadata.csv and projects_metadata.csv have a UTF-8 BOM prepended, causing the first column ('Run') to appear as '\\ufeffRun' with naive parsers.",
      "mitigation": "Use encoding='utf-8-sig' in Python: pd.read_csv(..., encoding='utf-8-sig')"
    },
    {
      "id": "RISK-007",
      "severity": "LOW",
      "description": "Minor count discrepancies between paper and live data",
      "detail": "Paper: 93 body sites, 101 phenotypes. Live API: 94 body sites, 102 phenotypes. Dataset has been updated since publication.",
      "mitigation": "Accept live data as ground truth. Do not hard-code expected counts in the plugin."
    }
  ]
}
