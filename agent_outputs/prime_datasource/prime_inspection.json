  "api_crawl_details": {
    "base_url": "https://primedb.sjtu.edu.cn/api/v1",
    "authentication": "none",
    "rate_limits": "none stated",
    "live_status": "operational (confirmed 2026-06-29)",
    "response_format": "JSON (camelCase) or CSV for abundance endpoints",
    "endpoints": [
      {"path": "/api/v1/health", "method": "GET", "response": {"status": "ok", "version": "v1", "database": "connected"}},
      {"path": "/api/v1/stats", "method": "GET", "response_summary": "53449 samples, 111 projects, 94 body sites, 84 countries, 25401 GG taxa, 12042 SILVA taxa"},
      {"path": "/api/v1/samples/list", "method": "GET", "response_summary": "Flat array of all 53,449 SRA run accession strings. No pagination, no metadata."},
      {"path": "/api/v1/samples/:run/stats", "method": "GET", "example_id": "DRR396973", "response_summary": "Full per-sample metadata (all 85 fields). One HTTP call per sample — not suited for bulk."},
      {"path": "/api/v1/projects/list", "method": "GET", "response_summary": "111 project accession strings."},
      {"path": "/api/v1/projects/:accession/stats", "method": "GET", "response_summary": "Rich project metadata with distribution breakdowns for phenotype, body site, country."},
      {"path": "/api/v1/phenotypes/list", "method": "GET", "response_summary": "102 phenotypes with IDs."},
      {"path": "/api/v1/bodysites/list", "method": "GET", "response_summary": "94 body sites with IDs and system."},
      {"path": "/api/v1/taxa/:db/list", "method": "GET", "response_summary": "Full taxonomic tree. SILVA: 12,042 nodes; GG: 25,401 nodes. Fields: taxonId, taxonName, rank, parentId, fullName."},
      {"path": "/api/v1/abundances/sample/:db/:rank/:type", "method": "POST", "body": {"runs": ["DRR396973"]}, "response": "CSV (samples x taxa subset for requested runs)."},
      {"path": "/api/v1/abundances/cache/:db/:rank/:type", "method": "GET", "note": "Returns full abundance CSV for all samples — same content as Zenodo files. Hit 10MB content limit in testing."}
    ],
    "api_use_recommendation": "API is valuable for: (1) lookup tables (phenotype/bodysite/taxa IDs), (2) per-project distribution stats for metadata enrichment. NOT suitable for bulk abundance ingestion — use Zenodo CSVs."
  },

