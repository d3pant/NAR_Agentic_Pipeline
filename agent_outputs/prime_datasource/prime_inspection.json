    {"claim": "6 download files on Zenodo", "observed": "29 total files — 24 abundance CSVs (phylum/class/order/family/genus/species x absolute/relative x SILVA/GG) + 2 metadata CSVs + 2 QIIME2 classifiers + 1 Python client. ~9.1 GB total data.", "match": false},
    {"claim": "License: CC BY 4.0 + MIT", "observed": "Confirmed. Zenodo API shows cc-by-4.0 for dataset; MIT for Python client tarball only.", "match": true},
