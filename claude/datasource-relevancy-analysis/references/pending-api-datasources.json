    "pending_biothings_io": {
        "description": "APIs hosted at pending.biothings.io, typically in staging or evaluation for eventual inclusion in core BioThings APIs",
        "portal": "https://pending.biothings.io",
        "known_apis": [
            {
                "name": "PFOCR (pending)",
                "api_url": "https://pending.biothings.io/pfocr",
                "status": "staging"
            }
        ]
    },
    "open_data_source_evaluations": {
        "description": "Data sources that have been discussed in GitHub issues for potential inclusion but may not yet be deployed",
        "issues_url": "https://github.com/biothings/pending.api/issues?q=label%3A%22data+source%22",
        "known_candidates": [
            {
                "name": "Polygenic Priority Score (PoPS)",
